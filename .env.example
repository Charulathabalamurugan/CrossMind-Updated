# CrossMind Configuration
HOST=0.0.0.0
PORT=8000

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_IN_MEMORY=True
QDRANT_COLLECTION_NAME=crossmind_knowledge

# Yuuki RxG Nano Engine Configuration
RXG_NANO_MODEL_NAME=OpceanAI/Yuuki-RxG-nano
RXG_NANO_API_BASE=http://localhost:8000/v1
RXG_NANO_TEMPERATURE=0.2
RXG_NANO_MAX_TOKENS=4096
USE_LOCAL_SIMULATOR_FALLBACK=True

# Ingestion / Embedding Configuration
EMBEDDING_MODEL_NAME=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=256

# Dashboard / monitoring
API_BASE=http://localhost:8000
